#!/usr/bin/env bash
# .zai/validate-config — validate config.json schema (v7)
# Usage: bash .zai/validate-config [--config PATH] [--strict]
#   --config P  path to config.json (default: .zai/config.json)
#   --strict    treat warnings as errors
# Exit: 0 = valid, 1 = invalid
# Called by: setup.sh, user manually

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${SCRIPT_DIR}/config.json"
# Convert MSYS path (/c/...) to Windows path (C:/...) for Node on Windows.
# cygpath is available in Git Bash; absent in Linux sandbox, where the
# original path already works. See SESSION_NOTES / worklog 2026-07-04.
if command -v cygpath &>/dev/null; then
    CONFIG_FILE="$(cygpath -m "$CONFIG_FILE")"
fi
STRICT="false"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --config) CONFIG_FILE="$2"; shift 2 ;;
        --strict) STRICT="true"; shift ;;
        *)        echo "Unknown option: $1"; exit 2 ;;
    esac
done

echo "=== Config Validation ==="
echo "File: ${CONFIG_FILE}"
echo ""

ERRORS=0
WARNINGS=0

# Check file exists
if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "[FAIL] Config file not found: $CONFIG_FILE"
    exit 1
fi

# Check valid JSON
if ! node -e "JSON.parse(require('fs').readFileSync('$CONFIG_FILE','utf8'))" 2>/dev/null; then
    echo "[FAIL] Invalid JSON"
    exit 1
fi
echo "[OK] Valid JSON"

# Check version format (semver — supports pre-release and build metadata)
VERSION=$(node -e "const c=JSON.parse(require('fs').readFileSync('$CONFIG_FILE','utf8')); console.log(c.version ?? '')" 2>/dev/null)
if [[ -n "$VERSION" ]]; then
    # Full semver: X.Y.Z[-prerelease][+build]
    if echo "$VERSION" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z-]+(\.[0-9A-Za-z-]+)*)?(\+[0-9A-Za-z-]+(\.[0-9A-Za-z-]+)*)?$'; then
        echo "[OK] version = $VERSION (valid semver)"
    else
        echo "[WARN] version = $VERSION (expected semver X.Y.Z)"
        WARNINGS=$((WARNINGS + 1))
    fi
else
    echo "[WARN] version missing"
    WARNINGS=$((WARNINGS + 1))
fi

# Check required fields
check_field() {
    local path="$1"
    local type="$2"
    local value

    value=$(node -e "
        const c = JSON.parse(require('fs').readFileSync('$CONFIG_FILE','utf8'));
        const v = $path;
        console.log(v === undefined ? 'MISSING' : typeof v === '$type' ? 'OK' : 'WRONG_TYPE:' + typeof v);
    " 2>/dev/null)

    case "$value" in
        OK)
            echo "[OK] $path ($type)"
            ;;
        MISSING)
            echo "[WARN] $path missing (will use default)"
            ;;
        WRONG_TYPE:*)
            echo "[FAIL] $path expected $type, got ${value#WRONG_TYPE:}"
            ERRORS=$((ERRORS + 1))
            ;;
        *)
            echo "[FAIL] $path unexpected: $value"
            ERRORS=$((ERRORS + 1))
            ;;
    esac
}

echo ""
echo "--- Required fields ---"
check_field "c.line_count" "object"
check_field "c.line_count.limit" "number"
check_field "c.worklog" "object"
check_field "c.worklog.paths" "object"
check_field "c.emoji" "object"
check_field "c.emoji.enabled" "boolean"

echo ""
echo "--- Value checks ---"

# line_count.limit > 0
LIMIT=$(node -e "const c=JSON.parse(require('fs').readFileSync('$CONFIG_FILE','utf8')); console.log(c.line_count?.limit ?? 500)" 2>/dev/null)
if [[ "$LIMIT" -gt 0 ]] 2>/dev/null; then
    echo "[OK] line_count.limit = $LIMIT (> 0)"
else
    echo "[FAIL] line_count.limit = $LIMIT (must be > 0)"
    ERRORS=$((ERRORS + 1))
fi

# worklog.min_lines > 0
MIN_LINES=$(node -e "const c=JSON.parse(require('fs').readFileSync('$CONFIG_FILE','utf8')); console.log(c.worklog?.min_lines ?? 1)" 2>/dev/null)
if [[ "$MIN_LINES" -gt 0 ]] 2>/dev/null; then
    echo "[OK] worklog.min_lines = $MIN_LINES (> 0)"
else
    echo "[FAIL] worklog.min_lines = $MIN_LINES (must be > 0)"
    ERRORS=$((ERRORS + 1))
fi

# worklog.paths is non-empty array
PATHS_COUNT=$(node -e "const c=JSON.parse(require('fs').readFileSync('$CONFIG_FILE','utf8')); console.log((c.worklog?.paths ?? []).length)" 2>/dev/null)
if [[ "$PATHS_COUNT" -gt 0 ]] 2>/dev/null; then
    echo "[OK] worklog.paths has $PATHS_COUNT entries"
else
    echo "[FAIL] worklog.paths is empty"
    ERRORS=$((ERRORS + 1))
fi

# emoji.extensions is array
EXT_COUNT=$(node -e "const c=JSON.parse(require('fs').readFileSync('$CONFIG_FILE','utf8')); console.log((c.emoji?.extensions ?? []).length)" 2>/dev/null)
if [[ "$EXT_COUNT" -gt 0 ]] 2>/dev/null; then
    echo "[OK] emoji.extensions has $EXT_COUNT entries"
else
    echo "[WARN] emoji.extensions is empty (no files will be checked)"
fi

# exclude_dirs is array
EXCLUDE_COUNT=$(node -e "const c=JSON.parse(require('fs').readFileSync('$CONFIG_FILE','utf8')); console.log((c?.exclude_dirs ?? []).length)" 2>/dev/null)
if [[ "$EXCLUDE_COUNT" -gt 0 ]] 2>/dev/null; then
    echo "[OK] exclude_dirs has $EXCLUDE_COUNT entries"
else
    echo "[WARN] exclude_dirs is empty"
fi

echo ""
echo "=== Summary ==="
if [[ "$ERRORS" -gt 0 ]]; then
    echo "RESULT: INVALID ($ERRORS errors)"
    exit 1
elif [[ "$WARNINGS" -gt 0 ]] && [[ "$STRICT" == "true" ]]; then
    echo "RESULT: INVALID (strict mode, $WARNINGS warnings)"
    exit 1
elif [[ "$WARNINGS" -gt 0 ]]; then
    echo "RESULT: VALID ($WARNINGS warnings)"
    exit 0
else
    echo "RESULT: VALID"
    exit 0
fi
