# Enforce LF line endings for shell scripts (required for bash on Linux)
*.sh text eol=lf

# Enforce LF for other scripts
*.bash text eol=lf
*.py text eol=lf

# Enforce LF for config files
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf

# Enforce LF for husky hooks
.husky/* text eol=lf

# Keep CRLF for Windows-specific files if any
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf
